# ────────────────────────────────────────────────────────────
# Databas (PostgreSQL)
# ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/database"

# ────────────────────────────────────────────────────────────
# NextAuth
# ────────────────────────────────────────────────────────────
# Generera med: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# ────────────────────────────────────────────────────────────
# Publik app-URL (används i e-postlänkar för lösenordsåterställning)
# ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ────────────────────────────────────────────────────────────
# Inbjudningskod (reservlösning om inga aktiveringskoder finns i DB)
# ────────────────────────────────────────────────────────────
INVITE_CODE="CASECORE2026"

# ────────────────────────────────────────────────────────────
# Administratörskonto (den e-postadress som alltid är admin)
# ────────────────────────────────────────────────────────────
ADMIN_EMAIL="admin@casecore.se"

# ────────────────────────────────────────────────────────────
# Resend (e-post för lösenordsåterställning)
# ────────────────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# ────────────────────────────────────────────────────────────
# AWS S3 (dokumentuppladdningar)
# ────────────────────────────────────────────────────────────
AWS_REGION="eu-north-1"
AWS_ACCESS_KEY_ID="xxxxxxxxxxxxxxxxxxxx"
AWS_SECRET_ACCESS_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
AWS_BUCKET_NAME="your-bucket-name"
