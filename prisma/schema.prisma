generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  firmName     String?       @default("Advokatbyrån AB")
  bankgiro     String?  
  password     String
  logo         String?  
  cases        Case[]
  conflictLogs ConflictLog[]
  createdAt    DateTime      @default(now())
}

model Client {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  orgNr        String?
  kycCompleted Boolean  @default(false)
  pepStatus    Boolean  @default(false)
  kycNotes     String?
  isAnonymized Boolean  @default(false)
  cases        Case[]
  createdAt    DateTime @default(now())
}

model Case {
  id            String        @id @default(cuid())
  title         String
  description   String?
  status        String        @default("OPEN")
  caseType      String?       // DISPUTE, PROPERTY, WILL, CONTRACT, OTHER
  invoiceStatus String        @default("UNBILLED") 
  hourlyRate    Float         @default(2000)
  budgetedHours Float?        // Planerad arbetstid
  opposingParty String?       // Motpart i tvisten
  courtName     String?       // Domstol om tillämplig
  caseDeadline  DateTime?     // Ärendets slutdatum
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id])
  assignedToId  String?
  assignedTo    User?         @relation(fields: [assignedToId], references: [id])
  logs          Log[]
  documents     Document[]
  timeEntries   TimeEntry[]
  tasks         Task[]
  expenses      Expense[]
  deadlines     Deadline[]
  invoices      Invoice[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model ConflictLog {
  id           String   @id @default(cuid())
  searchTerm   String
  matchesFound Int
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())
}

model Expense {
  id          String   @id @default(cuid())
  description String
  amount      Float
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id])
  createdAt   DateTime @default(now())
}

model Task {
  id          String   @id @default(cuid())
  title       String
  isCompleted Boolean  @default(false)
  dueDate     DateTime?
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id])
  createdAt   DateTime @default(now())
}

model Log {
  id        String   @id @default(cuid())
  action    String
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id])
  createdAt DateTime @default(now())
}

model Document {
  id        String   @id @default(cuid())
  name      String
  url       String
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id])
  createdAt DateTime @default(now())
}

model TimeEntry {
  id          String   @id @default(cuid())
  description String
  hours       Float
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id])
  createdAt   DateTime @default(now())
}

model CustomTemplate {
  id        String   @id @default(cuid())
  name      String
  content   String
  createdAt DateTime @default(now())
}

// NY MODELL: För lösenordsåterställning
model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

// NY MODELL: Juridiska deadlines och milestones
model Deadline {
  id          String   @id @default(cuid())
  title       String   // t.ex "Slutförande", "Domstolsförhandling", "Klagotid löper ut"
  description String?
  dueDate     DateTime
  type        String   @default("REMINDER") // LAW_DEADLINE, COURT_DATE, REMINDER, OTHER
  isCompleted Boolean  @default(false)
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// NY MODELL: Fakturor
model Invoice {
  id            String         @id @default(cuid())
  invoiceNumber String         @unique // t.ex "2025-001", "2025-002"
  invoiceDate   DateTime       @default(now())
  dueDate       DateTime       // Förfallodag
  status        String         @default("DRAFT") // DRAFT, SENT, PAID, OVERDUE
  totalAmount   Float
  notes         String?        // Villkor, betalningsinstruktioner etc
  caseId        String
  case          Case           @relation(fields: [caseId], references: [id])
  items         InvoiceItem[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// NY MODELL: Fakturarader
model InvoiceItem {
  id          String   @id @default(cuid())
  description String   // t.ex "Juridisk rådgivning", "Domstolsföreträde"
  quantity    Float    @default(1.0)
  unitPrice   Float
  amount      Float    // quantity * unitPrice - beräknas vid skapa
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}