generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  firmName     String?       @default("Advokatbyrån AB")
  bankgiro     String?  
  password     String
  logo         String?  
  cases        Case[]
  conflictLogs ConflictLog[] // NYTT: Koppling till jävsloggar
  createdAt    DateTime      @default(now())
}

model Client {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  orgNr        String?
  kycCompleted Boolean  @default(false)
  pepStatus    Boolean  @default(false)
  kycNotes     String?
  isAnonymized Boolean  @default(false)
  cases        Case[]
  createdAt    DateTime @default(now())
}

model Case {
  id            String      @id @default(cuid())
  title         String
  description   String?
  status        String      @default("OPEN")
  invoiceStatus String      @default("UNBILLED") 
  hourlyRate    Float       @default(2000)
  clientId      String
  client        Client      @relation(fields: [clientId], references: [id])
  assignedToId  String?
  assignedTo    User?       @relation(fields: [assignedToId], references: [id])
  logs          Log[]
  documents     Document[]
  timeEntries   TimeEntry[]
  tasks         Task[]
  expenses      Expense[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

// NY MODELL: Jävsprövnings-logg (Audit Trail)
model ConflictLog {
  id           String   @id @default(cuid())
  searchTerm   String
  matchesFound Int
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())
}

model Expense {
  id          String   @id @default(cuid())
  description String
  amount      Float
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id])
  createdAt   DateTime @default(now())
}

model Task {
  id          String   @id @default(cuid())
  title       String
  isCompleted Boolean  @default(false)
  dueDate     DateTime?
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id])
  createdAt   DateTime @default(now())
}

model Log {
  id        String   @id @default(cuid())
  action    String
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id])
  createdAt DateTime @default(now())
}

model Document {
  id        String   @id @default(cuid())
  name      String
  url       String
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id])
  createdAt DateTime @default(now())
}

model TimeEntry {
  id          String   @id @default(cuid())
  description String
  hours       Float
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id])
  createdAt   DateTime @default(now())
}

model CustomTemplate {
  id        String   @id @default(cuid())
  name      String
  content   String
  createdAt DateTime @default(now())
}