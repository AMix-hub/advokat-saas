generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String           @id @default(cuid())
  email         String           @unique
  name          String?
  firmName      String?          @default("Advokatbyrån AB")
  firmId        String?
  firm          Firm?            @relation(fields: [firmId], references: [id])
  bankgiro      String?  
  password      String
  logo          String?
  isAdmin       Boolean          @default(false)
  modules       String[]         @default([])  // Aktiverade tillägg, t.ex. ["docs", "kyc", "kommunikation"]
  cases         Case[]
  conflictLogs  ConflictLog[]
  internalComments InternalComment[]
  createdAgreements Agreement[]   @relation("CreatedBy")
  sentMessages      Message[]      @relation("SentMessages")
  generatedDocuments GeneratedDocument[] @relation("GeneratedDocuments")
  createdClients    Client[]       @relation("CreatedClients")
  createdAt     DateTime         @default(now())
}

model Client {
  id           String   @id @default(cuid())
  name         String
  email        String
  orgNr        String?
  kycCompleted Boolean  @default(false)
  pepStatus    Boolean  @default(false)
  kycNotes     String?
  isAnonymized Boolean  @default(false)
  createdById  String?
  createdBy    User?    @relation("CreatedClients", fields: [createdById], references: [id], onDelete: SetNull)
  cases        Case[]
  messages     Message[]
  kycRecords   KycRecord[]
  createdAt    DateTime @default(now())

  @@unique([email, createdById])
}

model Case {
  id            String              @id @default(cuid())
  title         String
  description   String?
  status        String              @default("OPEN")
  caseType      String?             // DISPUTE, PROPERTY, WILL, CONTRACT, OTHER
  invoiceStatus String              @default("UNBILLED") 
  hourlyRate    Float               @default(2000)
  budgetedHours Float?              // Planerad arbetstid
  opposingParty String?             // Motpart i tvisten
  courtName     String?             // Domstol om tillämplig
  caseDeadline  DateTime?           // Ärendets slutdatum
  clientId      String
  client        Client              @relation(fields: [clientId], references: [id])
  firmId        String?
  firm          Firm?               @relation("FirmCases", fields: [firmId], references: [id])
  assignedToId  String?
  assignedTo    User?               @relation(fields: [assignedToId], references: [id])
  logs          Log[]
  documents     Document[]
  timeEntries   TimeEntry[]
  tasks         Task[]
  expenses      Expense[]
  deadlines     Deadline[]
  invoices      Invoice[]
  internalComments InternalComment[]
  agreements    Agreement[]
  messages      Message[]
  generatedDocuments GeneratedDocument[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model ConflictLog {
  id           String   @id @default(cuid())
  searchTerm   String
  matchesFound Int
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())
}

model Expense {
  id          String   @id @default(cuid())
  description String
  amount      Float
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id])
  createdAt   DateTime @default(now())
}

model Task {
  id          String   @id @default(cuid())
  title       String
  isCompleted Boolean  @default(false)
  dueDate     DateTime?
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id])
  createdAt   DateTime @default(now())
}

model Log {
  id        String   @id @default(cuid())
  action    String
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id])
  createdAt DateTime @default(now())
}

model Document {
  id        String   @id @default(cuid())
  name      String
  url       String
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id])
  createdAt DateTime @default(now())
}

model TimeEntry {
  id          String   @id @default(cuid())
  description String
  hours       Float
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id])
  createdAt   DateTime @default(now())
}

model CustomTemplate {
  id        String   @id @default(cuid())
  name      String
  content   String
  createdAt DateTime @default(now())
}

// NY MODELL: För lösenordsåterställning
model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

// NY MODELL: Juridiska deadlines och milestones
model Deadline {
  id          String   @id @default(cuid())
  title       String   // t.ex "Slutförande", "Domstolsförhandling", "Klagotid löper ut"
  description String?
  dueDate     DateTime
  type        String   @default("REMINDER") // LAW_DEADLINE, COURT_DATE, REMINDER, OTHER
  isCompleted Boolean  @default(false)
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// NY MODELL: Fakturor
model Invoice {
  id            String         @id @default(cuid())
  invoiceNumber String         @unique // t.ex "2025-001", "2025-002"
  invoiceDate   DateTime       @default(now())
  dueDate       DateTime       // Förfallodag
  status        String         @default("DRAFT") // DRAFT, SENT, PAID, OVERDUE
  totalAmount   Float
  notes         String?        // Villkor, betalningsinstruktioner etc
  caseId        String
  case          Case           @relation(fields: [caseId], references: [id])
  items         InvoiceItem[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// NY MODELL: Fakturarader
model InvoiceItem {
  id          String   @id @default(cuid())
  description String   // t.ex "Juridisk rådgivning", "Domstolsföreträde"
  quantity    Float    @default(1.0)
  unitPrice   Float
  amount      Float    // quantity * unitPrice - beräknas vid skapa
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

// NY MODELL: Multi-tenant - Firma/Byrå
model Firm {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  cvr             String?  // CVR-nummer för danske/norske firmer
  orgNumber       String?  // Organisationsnummer
  address         String?
  phone           String?
  website         String?
  users           User[]
  cases           Case[]   @relation("FirmCases")
  agreements      Agreement[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// NY MODELL: Interner kommentarer (privata anteckningar)
model InternalComment {
  id          String   @id @default(cuid())
  content     String   @db.Text
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// NY MODELL: Avtal och överenskommelser
model Agreement {
  id              String   @id @default(cuid())
  title           String   // t.ex "Klientöverenskommelse", "Honoraravtal"
  type            String   @default("CLIENT_AGREEMENT") // CLIENT_AGREEMENT, HOURLY_RATE, CONTINGENCY, OTHER
  content         String   @db.Text
  status          String   @default("ACTIVE") // ACTIVE, ARCHIVED, SUPERSEDED
  startDate       DateTime
  endDate         DateTime?
  version         Int      @default(1)
  firmId          String?
  firm            Firm?    @relation(fields: [firmId], references: [id])
  caseId          String?
  case            Case?    @relation(fields: [caseId], references: [id], onDelete: SetNull)
  createdById     String
  createdBy       User     @relation("CreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  changes         AgreementChange[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// NY MODELL: Avtalshistorik
model AgreementChange {
  id          String   @id @default(cuid())
  agreementId String
  agreement   Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  oldVersion  String   @db.Text
  newVersion  String   @db.Text
  description String?
  changedAt   DateTime @default(now())
}

// NY MODELL: Aktiverings-/inbjudningskoder för registrering
model ActivationCode {
  id          String    @id @default(cuid())
  code        String    @unique
  description String?
  licenseType String    @default("SOLO")  // SOLO | BYRA
  maxUses     Int       @default(1)  // -1 = obegränsat antal användningar
  usedCount   Int       @default(0)
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// NY MODELL: Klientkommunikation – meddelanden mellan jurist och klient
model Message {
  id         String   @id @default(cuid())
  subject    String
  body       String   @db.Text
  direction  String   @default("OUTBOUND") // OUTBOUND (till klient) | INBOUND (från klient)
  isRead     Boolean  @default(false)
  senderId   String?
  sender     User?    @relation("SentMessages", fields: [senderId], references: [id], onDelete: SetNull)
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  caseId     String?
  case       Case?    @relation(fields: [caseId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
}

// NY MODELL: E-mail och SMS-logg
model NotificationLog {
  id            String   @id @default(cuid())
  type          String   // EMAIL, SMS
  recipient     String   // Email eller telefonnummer
  subject       String?
  message       String   @db.Text
  status        String   @default("PENDING") // PENDING, SENT, FAILED, BOUNCED
  caseId        String?
  deadlineId    String?
  invoiceId     String?
  retries       Int      @default(0)
  error         String?  @db.Text
  sentAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// CaseCore Docs: Sparade genererade dokument
model GeneratedDocument {
  id           String   @id @default(cuid())
  templateName String
  content      String   @db.Text
  variables    String   @db.Text  // JSON-kodade nyckel-värde-par
  caseId       String?
  case         Case?    @relation(fields: [caseId], references: [id], onDelete: SetNull)
  createdById  String?
  createdBy    User?    @relation("GeneratedDocuments", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
}

// CaseCore KYC: Detaljerade KYC-bedömningar per klient
model KycRecord {
  id               String    @id @default(cuid())
  clientId         String
  client           Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  riskLevel        String    @default("LOW")  // LOW, MEDIUM, HIGH
  pepChecked       Boolean   @default(false)
  pepResult        Boolean   @default(false)   // true = PEP-träff hittad
  sanctionsChecked Boolean   @default(false)
  sanctionsResult  Boolean   @default(false)   // true = träff på sanktionslista
  idVerified       Boolean   @default(false)
  sourceOfFunds    String?
  notes            String?   @db.Text
  reviewer         String?
  reviewedAt       DateTime?
  expiresAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}